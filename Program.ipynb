    "# Fungsi load_data\n",
    "def load_data(folder_path, class_name=None):\n",
    "    # Inisialisasi face_list & label_list\n",
    "    face_list = []\n",
    "    label_list = []\n",
    "\n",
    "    # Validasi apakah class_name ada\n",
    "    if class_name is None: \n",
    "        class_name = sorted(os.listdir(folder_path)) # ambil class name dari folder yang sorted\n",
    "\n",
    "    # Buat for loop folder tiap s(enumerate untuk load semua data)\n",
    "    for label, person_name in enumerate(class_name):\n",
    "        person_folder = os.path.join(folder_path, person_name) # path lengkap ke folder orang tersebut\n",
    "\n",
    "        # Validasi ada nga folder s\n",
    "        if not os.path.isdir(person_folder): # skip file yang bukan folder\n",
    "            print(f\"Warning: {person_folder} is not a directory!\")\n",
    "            continue\n",
    "\n",
    "        for img_name in sorted(os.listdir(person_folder)):\n",
    "\n",
    "            # Validasi format gambar\n",
    "            if not img_name.lower().endswith((\".jpg\", \".png\",\".pgm\")):\n",
    "                print(f\"Warning: {img_name} is not a supported img format\")\n",
    "                continue\n",
    "            \n",
    "            # Insialiasi img_path dan img_gray & nanti validasi ada ngak img_gray\n",
    "            img_path = os.path.join(person_folder, img_name)\n",
    "            img_gray = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)\n",
    "\n",
    "            if img_gray is None:\n",
    "                print(f\"Could not read {img_gray}\")\n",
    "                continue\n",
    "\n",
    "            face_img = detect_and_crop_face(img_gray)\n",
    "\n",
    "            # Validasi di face_img ada face atau ngak\n",
    "            if face_img is None:\n",
    "                print(f\"There is no face in {face_img} image\")\n",
    "                continue\n",
    "\n",
    "            face_list.append(face_img)\n",
    "            label_list.append(label_list)\n",
    "    return face_list, np.array(label_list, dtype=np.int32), class_name\n",
    "                "
   ]
  },
