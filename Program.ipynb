    "# Fungsi Preprocess\n",
    "def preprocess_face(face_img):\n",
    "    # lakukan resize dan equalizhist\n",
    "    face_img = cv2.resize(face_img, (100,100))\n",
    "    face_img = cv2.equalizeHist(face_img)\n",
    "    return face_img"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 41,
   "id": "81dfdfce",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fungsi detect and crop face\n",
    "def detect_and_crop_face(img_gray):\n",
    "    # Cari detected face\n",
    "    detected_face = face_cascades.detectMultiScale(\n",
    "        img_gray,\n",
    "        scaleFactor=1.05,\n",
    "        minNeighbors=2,\n",
    "        minSize=(30,30)\n",
    "    )\n",
    "\n",
    "    # Validasi ada wajah atau tidak, kalau ngak ada kasih None, None\n",
    "    if len(detected_face) < 1:\n",
    "        return None, None\n",
    "    \n",
    "    x, y, w, h = max(detected_face, key=lambda rect: rect[2]*rect[3]) # ingat KLR, rect[2] = panjang & rect[3] = lebar \n",
    "    face_img = img_gray[y: y+h, x: x+w] # [baris, kolom]\n",
    "    face_img = preprocess_face(face_img)\n",
    "    face_box = (x, y, w, h) # koordinat kotak wajah\n",
    "    return face_img, face_box"
   ]
  },
