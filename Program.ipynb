    "def detect_and_crop_face(img_gray):\n",
    "    # Cari detected_face\n",
    "    detected_face = face_cascades.detectMultiScale(\n",
    "        img_gray,\n",
    "        scaleFactor=1.05,\n",
    "        minNeighbors=2,\n",
    "        minSize=(30,30)\n",
    "    )\n",
    "\n",
    "    # Validasi kalau detected_face ada\n",
    "    if len(detected_face) < 1:\n",
    "        return None, None\n",
    "    \n",
    "    # Dapatkan face_img, face_box\n",
    "    x, y, w, h = max(detected_face, key=lambda req: req[2]*req[3])\n",
    "    face_img = img_gray[y: y+h, x: x+w] # [baris, kolom]\n",
    "    face_img = preprocess_face(face_img)\n",
    "    face_box = (x, y, w, h)\n",
    "    return face_img, face_box"
   ]
  },
