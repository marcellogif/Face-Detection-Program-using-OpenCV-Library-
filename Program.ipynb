    "# Buat fungsi predict Picture\n",
    "def predict_picture():\n",
    "    # input path & load model (serta validasi jika ada)\n",
    "    path_input = input(\"Enter Path!\")\n",
    "    face_recognizer, class_names = load_saved_model()\n",
    "    if face_recognizer is None:\n",
    "        print(\"WARNING: model does not exist\")\n",
    "        return\n",
    "    \n",
    "    # buat img_gray (janlup validasi) untuk mendapat face_img (janlup validasi) & face_box dari fungsi detect_and_crop_face\n",
    "    img_gray = cv2.imread(path_input, cv2.IMREAD_GRAYSCALE)\n",
    "    if img_gray is None:\n",
    "        print(f\"WARNING: {img_gray} does not exist\")\n",
    "        return\n",
    "    face_img, face_box = detect_and_crop_face(img_gray)\n",
    "    if face_img is None:\n",
    "        print(f\"WARNING: {face_img} does not exist\")\n",
    "        return\n",
    "    \n",
    "    # lakukan prediksi dan masukkan ke predicted_label (janlup confidence), inisialisasi (x,y,w,h) dari face_box. Buat threshold = 70\n",
    "    predicted_label, confidence = face_recognizer.predict(face_img)\n",
    "    x,y,w,h = face_box\n",
    "    threshold = 70\n",
    "\n",
    "    # If statement jika confidence lebih rendah dari threshold maka benar, jika tidak salah\n",
    "    if confidence < threshold:\n",
    "        predicted_name = class_names[predicted_label]\n",
    "        color = (0, 255, 0)\n",
    "    else:\n",
    "        predicted_name = class_names[predicted_label]\n",
    "        color = (0, 0, 255)\n",
    "    \n",
    "    # Print predicted_name, confidence, dan lokasi face_box (x, y, w, h)\n",
    "    print(f\"{path_input} is detected as {predicted_name}!\")\n",
    "    print(f\"Confidence: {confidence}\")\n",
    "    print(f\"Face box coordination:\\nx = {x}\\ny = {y}\\nw = {w}\\nh = {h}\")\n",
    "    print(\"Lower LBPH confidence means better match\")\n",
    "\n",
    "    # inisialisasi display_img, cv2.rectangle, & text\n",
    "    display_img = cv2.cvtColor(img_gray, cv2.COLOR_GRAY2BGR)\n",
    "    cv2.rectangle(display_img,(x,y),(x+w,y+h), color, 2)\n",
    "    text = f\"{predicted_name} | {predicted_label}\"\n",
    "\n",
    "    # lakukan cv2.putText (lihat parameter sebagai panduan) \n",
    "    cv2.putText(\n",
    "        display_img,\n",
    "        text,\n",
    "        (x, max(y - 10, 20)), # ini mastiin text tidak keluar gambar\n",
    "        cv2.FONT_HERSHEY_COMPLEX,\n",
    "        6,\n",
    "        color,\n",
    "        2\n",
    "    )\n",
    "\n",
    "    # lakukan cv2.imshow, cv2.waitKey(0), & cv2.destroyAllWindows \n",
    "    cv2.imshow(\"Prediction Result\", display_img)\n",
    "    cv2.waitKey(0)\n",
    "    cv2.destroyAllWindows()"
   ]
  },
