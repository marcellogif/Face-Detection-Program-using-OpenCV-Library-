    "# Buat fungsi train_test_model\n",
    "def train_test_model():\n",
    "    # Inisialisasi face_regognizer -> modelnya\n",
    "    face_recognizer = cv2.face.LBPHFaceRecognizer_create()\n",
    "    \n",
    "    # Masukkan train data dan validasi jika ada\n",
    "    print(f\"Loading training data\")\n",
    "    train_faces, train_labels, class_names = load_data(TRAIN_PATH)\n",
    "\n",
    "    if len(train_faces) == 1:\n",
    "        print(f\"WARNING: {train_faces} does not exist!\")\n",
    "        return # gantinya continue itu return\n",
    "\n",
    "    # Latih model\n",
    "    print(\"Training model\")\n",
    "    face_recognizer.train(train_faces, train_labels)\n",
    "    face_recognizer.save(MODEL_PATH)\n",
    "    print(f\"Model saved to: {MODEL_PATH}\")\n",
    "\n",
    "    # Load test data dan validasi jika ada\n",
    "    test_faces, test_labels, _ = load_data(TEST_PATH)\n",
    "\n",
    "    if len(test_faces) == 0:\n",
    "        print(f\"WARNING: There is nothing in {TEST_PATH}\")\n",
    "        return\n",
    "    \n",
    "    correct_predict = 0\n",
    "    total = len(test_faces)\n",
    "\n",
    "    # Buat for loop untuk melihat prediksi model di setiap gambar\n",
    "    print(\"\\nTesting result\")\n",
    "    for face_img, true_label in zip(test_faces, test_labels):\n",
    "        predicted_label, confidence = face_recognizer.predict(face_img)\n",
    "\n",
    "        true_name = class_names[true_label]\n",
    "        predicted_name = class_names[predicted_label]\n",
    "\n",
    "        if true_name == predicted_name:\n",
    "            correct_predict += 1\n",
    "            status = \"CORRECT\"\n",
    "        else:\n",
    "            status = \"WRONG\"\n",
    "\n",
    "        print(\n",
    "            f\"Actual: {true_name} | \"\n",
    "            f\"Predicted: {predicted_label}|\"\n",
    "            f\"Confidence: {confidence:.2f}|\"\n",
    "            f\"{status}\")\n",
    "    \n",
    "    accuracy = (correct_predict/total) * 100\n",
    "    print(f\"Accuracy: {accuracy}%\")\n"
   ]
