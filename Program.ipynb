    "# Buat fungsi utnuk training & test model, ada dua part (Awal dan Akhir)\n",
    "def train_test_model():\n",
    "    #Part Awal: inisialisasi model\n",
    "    face_recognizer = cv2.face.LBPHFaceRecognizer_create()\n",
    "    \n",
    "    # Ambil data train_faces, label_face, & class_names. Kemudian validasi train_faces\n",
    "    train_faces, train_labels, class_name = load_data(TRAIN_PATH)\n",
    "    if len(train_faces) == 0:\n",
    "        print(\"WARNING: could not read train data\")\n",
    "        return\n",
    "    \n",
    "    # Training model\n",
    "    print(\"Training model...\")\n",
    "    face_recognizer.train(train_faces, train_labels)\n",
    "    face_recognizer.save(MODEL_PATH)\n",
    "    print(f\"Model saved to {MODEL_PATH}\")\n",
    "\n",
    "    # Load test data dan validasi jika ada, kemudian buat variabel correct_predictions & total\n",
    "    test_faces, test_labels, _ = load_data(TEST_PATH, class_name)\n",
    "    if len(test_faces) == 0:\n",
    "        print(\"WARNING: could not read test data\")\n",
    "        return\n",
    "    correct_prediction = 0\n",
    "    total = len(test_faces)\n",
    "    \n",
    "    # Part Akhir: buat for loop untuk mengecek kemampuang setiap test data\n",
    "    for face_img, true_label in zip(test_faces, test_labels):\n",
    "        # prediksi face_img\n",
    "        predicted_label, confidence = face_recognizer.predict(face_img) \n",
    "\n",
    "        # ambil true_face & predicted_face\n",
    "        true_face = class_name[true_label]\n",
    "        predicted_face = class_name[predicted_label]\n",
    "\n",
    "        # Bandingkan kedua label, jika benar maka buat correct_prediction +1\n",
    "        if true_label == predicted_label:\n",
    "            correct_prediction += 1\n",
    "            Status = \"CORRECT\"\n",
    "        else:\n",
    "            Status = \"WRONG\"\n",
    "        \n",
    "        # buatkan kesimpulan prediksi\n",
    "        print(\n",
    "            f\"Actual{true_face}\",\n",
    "            f\"Prediction: {predicted_face}\",\n",
    "            f\"Confidence: {confidence}\",\n",
    "            f\"Status: {Status}\"\n",
    "        )\n",
    "    \n",
    "    # get average accuracy score\n",
    "    avg_accuracy = (correct_prediction/total) * 100\n",
    "    print(f\"Average Accuracy: {avg_accuracy}\")\n"
   ]
  },
